# Brewfile.personal — personal-Mac-only additions (shared apps live in Brewfile.core)

# cli
brew 'gamdl'
brew 'railway'
brew 'node'
brew 'mkcert'
brew 'mosh'
brew 'terminal-notifier'
brew 'whisper-cpp'

# ios toolchain
brew 'cocoapods'
brew 'fastlane'
brew 'xcodegen'
brew 'rbenv'
brew 'ruby-build'

# apps
cask 'claude'        # desktop app
cask 'claude-code'   # the cli
cask '1password-cli'
cask 'ngrok'          # personal tunnel tool; corp TLS interception breaks its download
cask 'zoom'
cask 'android-studio'
cask 'zulu@17'
cask 'obsidian'
cask 'raspberry-pi-imager'
cask 'sf-symbols'
cask 'tailscale-app'
cask 'termius'
