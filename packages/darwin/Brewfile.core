# Brewfile.core — everything installed on EVERY Mac (personal + work)
tap 'oven-sh/bun'

# cli
brew 'bash'      # macOS ships bash 3.2 (2007); the dotfiles cli wants a modern one
brew 'git'
brew 'gh'
brew 'tmux'
brew 'starship'
brew 'gum'
brew 'fzf'
brew 'zoxide'
brew 'jq'
brew 'ripgrep'
brew 'oven-sh/bun/bun'
brew 'docker-compose'
brew 'ffmpeg'
brew 'yt-dlp'

# shared apps
cask '1password'
cask 'cleanshot'
cask 'discord'
cask 'elgato-control-center'
cask 'elgato-stream-deck'
cask 'firefox'
cask 'google-chrome'
cask 'pixelsnap'
cask 'sonos'
cask 'vanilla'
cask 'raycast'
cask 'granola'
cask 'screen-studio'
cask 'figma'
cask 'visual-studio-code'
cask 'docker-desktop'
cask 'postman'
cask 'slack'

# fonts
cask 'font-fira-mono-nerd-font'
