#!/usr/bin/env bash
# dotfiles-notify — agent completion/attention pings, called by agent hooks.
#
#   dotfiles-notify done        # agent finished its turn
#   dotfiles-notify input       # agent is blocked waiting on you
#
# Reads hook context from stdin when present (claude code passes JSON with cwd)
# but works bare. Figures out its project + tmux session from cwd, suppresses
# pings when that session is attached (you're watching), then:
#   - macOS: banner (terminal-notifier if present, else osascript) + sound
#   - everywhere: BEL into the session's pane tty so detached-but-open
#     terminals get a bell/badge through tmux
set -uo pipefail

kind=${1:-done}
payload=""
[[ -t 0 ]] || payload=$(cat 2>/dev/null || true)

# project dir: hook json cwd, else $PWD
dir=$PWD
if [[ $payload == *'"cwd"'* ]]; then
  d=$(printf '%s' "$payload" | sed -n 's/.*"cwd"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
  [[ -n $d ]] && dir=$d
fi
proj=$(basename "$dir")

# find the wrapping tmux session (cc-/cp- convention, else any session at that cwd)
sess=""
for cand in "cc-$proj" "cp-$proj"; do
  tmux has-session -t "=$cand" 2>/dev/null && { sess=$cand; break; }
done

# Suppress only when you're plausibly WATCHING: session attached AND you have
# typed in that tmux client within the last 60s. Attachment alone is not
# attention — cc leaves the session attached while you cmd-tab elsewhere,
# which silently ate every ping in v1.
if [[ -n $sess && $kind != test ]]; then
  now=$(date +%s) recent=0
  while IFS= read -r act; do
    [[ -n $act ]] && (( now - act < 60 )) && recent=1
  done < <(tmux list-clients -t "=$sess" -F '#{client_activity}' 2>/dev/null)
  (( recent )) && exit 0
fi

case $kind in
  input) title="🔔 $proj needs you" ;;
  test)  title="📟 dotfiles-notify test" ;;
  *)     title="✅ $proj is done" ;;
esac

# macOS: banner + sound — prefer our own Dot.app (banner reads "Dot",
# click focuses the session via its activation handler)
if [[ $(uname -s) == Darwin ]]; then
  if [[ -d $HOME/Applications/Dot.app ]]; then
    mkdir -p "${XDG_DATA_HOME:-$HOME/.local/share}/dotfiles"
    printf '%s' "$sess" > "${XDG_DATA_HOME:-$HOME/.local/share}/dotfiles/last-notify"
    open -na "$HOME/Applications/Dot.app" --args "$title" "agent session $proj" 2>/dev/null || true
  elif command -v terminal-notifier >/dev/null 2>&1; then
    # click: focus the exact terminal tab viewing the session, or open one
    exec_arg=()
    [[ -n $sess ]] && exec_arg=(-execute "$HOME/.local/bin/dotfiles-focus $sess")
    terminal-notifier -title "$title" -message "agent session $proj" \
      -group "dotfiles-$proj" -sound Morse ${exec_arg[@]+"${exec_arg[@]}"} >/dev/null 2>&1 || true
  else
    osascript -e "display notification \"agent session $proj\" with title \"$title\" sound name \"Morse\"" >/dev/null 2>&1 || true
  fi
fi

# everywhere: ring the bell inside the tmux pane so any open (even unfocused)
# terminal attached later/elsewhere gets the terminal's bell/badge treatment
if [[ -n $sess ]]; then
  tty=$(tmux display-message -t "=$sess" -p '#{pane_tty}' 2>/dev/null || true)
  [[ -n $tty && -w $tty ]] && printf '\a' > "$tty" 2>/dev/null || true
fi

exit 0
