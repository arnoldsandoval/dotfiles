#!/usr/bin/env bash
# dotfiles — CLI + TUI for managing this machine's dev environment.
# Run `dotfiles help` for usage.
set -euo pipefail

DOTFILES="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
export DOTFILES

# Fast path for the shell-startup nudge: no lib sourcing, prints at most 2 lines.
# (behind-count comes from the status file the background fetch maintains)
if [[ ${1:-} == nudge ]]; then
  status="${XDG_DATA_HOME:-$HOME/.local/share}/dotfiles/status"
  behind=$([[ -f $status ]] && sed -n 's/^behind=//p' "$status" | head -1)
  [[ -n $behind && $behind -gt 0 ]] && echo "dotfiles ⇣$behind behind — run 'dotfiles sync'"
  [[ -n $(git -C "$DOTFILES" status --porcelain 2>/dev/null) ]] \
    && echo "dotfiles ✎ uncommitted changes — run 'dotfiles save'"
  exit 0
fi

for f in core platform profile tui link pkg skills sync doctor menu-sessions; do
  # shellcheck disable=SC1090
  source "$DOTFILES/lib/$f.sh"
done

usage() {
  cat <<EOF
${C_BLD}dotfiles${C_OFF} — one repo for every machine (profile: $(profile_get 2>/dev/null || echo unset), $OS/$DISTRO)

${C_MAG}usage:${C_OFF} dotfiles [command]

  ${C_BLD}(no command)${C_OFF}         menu hub: sessions / sync / save / doctor / skills / bootstrap
  ${C_BLD}sessions${C_OFF}             per-project agent sessions in persistent tmux (alias: cc)
  ${C_BLD}bootstrap${C_OFF} [flags]    set up this machine — tiers 0..2, safe to re-run
                         --profile mac-personal|mac-work|vm   --tier N   --yes
  ${C_BLD}sync${C_OFF} [--auto]        pull (ff-only) + relink + refresh third-party skills
  ${C_BLD}save${C_OFF} [msg]           commit + push local config edits to every machine
  ${C_BLD}diff${C_OFF}                 show uncommitted config changes (alias: status)
  ${C_BLD}link${C_OFF}                 (re)apply symlinks; prunes links whose source is gone
  ${C_BLD}doctor${C_OFF}               drift report: links, packages, skills, git (exit 1 on findings)
  ${C_BLD}cleanup${C_OFF}              uninstall brew packages no Brewfile declares (confirms first)
  ${C_BLD}skills${C_OFF} [install]     list skills / install missing manifest entries
  ${C_BLD}fetch${C_OFF} [--maybe]      quiet background fetch (used by timers + shell startup)
  ${C_BLD}nudge${C_OFF}                one-line status: behind origin / uncommitted (shell startup)
  ${C_BLD}help${C_OFF}                 this

state: ~/.local/share/dotfiles   machine-local: ~/.config/zsh/local.zsh, ~/.gitconfig.local
docs:  README.md + docs/MIGRATION.md in \$DOTFILES ($DOTFILES)
EOF
}

cmd_bootstrap() {
  local profile="" tier="" yes=""
  while [[ $# -gt 0 ]]; do
    case $1 in
      --profile) profile=$2; shift 2 ;;
      --tier) tier=$2; shift 2 ;;
      --yes|-y) yes=1; shift ;;
      *) die "unknown flag: $1" ;;
    esac
  done
  export DOTFILES_YES=$yes

  ui_header "dotfiles bootstrap — $OS/$DISTRO"
  profile_ensure "$profile"

  if [[ -z $tier || $tier == 0 ]]; then
    log "tier 0: links + local stubs"
    apply_links
    bash "$DOTFILES/lib/gen-local.sh"
    bash "$DOTFILES/lib/install-hooks.sh"
  else
    # links are cheap + idempotent: refresh them on ANY bootstrap run so a
    # --tier N invocation never leaves freshly-pulled links unapplied
    apply_links --quiet || true
  fi
  if [[ -z $tier || $tier == 1 ]]; then
    log "tier 1: packages"
    install_packages_tier1
    skills_install_manifest
  fi
  if [[ -z $tier || $tier == 2 ]]; then
    log "tier 2: private extras"
    install_packages_tier2
  fi
  echo
  run_doctor || true
}

tui_hub() {
  # One-time notification setup probe (darwin): macOS offers no scriptable way
  # to QUERY notification permission, so fire a test ping once and ask. Yes →
  # stamped forever; no → open the right settings pane, re-ask next hub open.
  if [[ $OS == darwin && ! -f $STATE_DIR/notify-ok && -t 1 ]]; then
    "$DOTFILES/bin/dotfiles-notify" test
    if ui_confirm "notification check: did a 📟 banner just appear?"; then
      ensure_state_dir; touch "$STATE_DIR/notify-ok"
      ok "notifications verified — agents will ping you when done / blocked"
    else
      warn "enable: System Settings → Notifications → terminal-notifier → Allow"
      warn "(also allow your terminal app; will re-check next time you open the hub)"
      open "x-apple.systempreferences:com.apple.preference.notifications" 2>/dev/null || true
    fi
  fi
  while true; do
    local behind nudge=""
    behind=$(status_get behind); [[ -n $behind && $behind -gt 0 ]] && nudge=" (⇣$behind)"
    local choice
    choice=$(ui_choose "dotfiles — $(profile_get 2>/dev/null || echo unbootstrapped) on $DISTRO" \
      "sessions" "sync$nudge" "save" "doctor" "skills" "bootstrap" "repo shell (~/code/dotfiles)") || true
    case ${choice%% *} in
      sessions) sessions_menu --nested ;;
      sync*|sync) do_sync || true ;;
      save) do_save || true ;;
      doctor) run_doctor || true ;;
      skills) skills_list ;;
      bootstrap) cmd_bootstrap ;;
      repo) cd "$DOTFILES" && exec "${SHELL:-bash}" ;;   # shell IN the repo (esc = plain shell)
      quit|"") return 0 ;;
    esac
  done
}

case "${1:-}" in
  "") if [[ -t 0 && -t 1 ]]; then tui_hub; else usage; fi ;;
  sessions|menu) shift; sessions_menu "$@" ;;
  bootstrap) shift; cmd_bootstrap "$@" ;;
  link) shift; apply_links "$@" ;;
  sync) shift; do_sync "${1:-}" ;;
  save) shift; do_save "$*" ;;
  diff|status) git -C "$DOTFILES" status --short; git -C "$DOTFILES" --no-pager diff ;;
  fetch) if [[ ${2:-} == --maybe ]]; then maybe_fetch_async; else do_fetch; fi ;;
  doctor) run_doctor ;;
  cleanup) pkg_cleanup ;;
  skills) shift; case "${1:-list}" in list) skills_list ;; install) skills_install_manifest ;; *) skills_list ;; esac ;;
  -h|--help|help) usage ;;
  *) die "unknown command: $1 (try 'dotfiles help')" ;;
esac
